  "name": "Old Fashioned",
  "description": "经典威士忌鸡尾酒代表作，以糖、苦精与烈酒构建干净有力的层次，口感厚实且回味悠长。",
  "github": "terenzzzz",
  "ingredients": [
    { "quantity": "60", "measure": "ml", "ingredient": "波本威士忌" },
