    { "quantity": "2", "measure": "dash", "ingredient": "安高天娜苦精" },
    { "quantity": "1", "measure": "splash", "ingredient": "苏打水（可选）" }
  ],
  "directions": [
    "将方糖与苦精放入古典杯中，轻压溶解。",
